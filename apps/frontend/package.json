{
  "name": "frontend",
  "version": "0.1.0",
  "description": "Yen-Neram frontend - static-bundle multi-game shell. First game: 5-in-a-row.",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "node tools/svgo-themes.mjs && tsc --noEmit && vite build",
    "build:assets": "node tools/svgo-themes.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "size:why": "size-limit --why"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@size-limit/file": "^11.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.12.0",
    "@typescript-eslint/parser": "^8.12.0",
    "eslint": "^10.4.1",
    "prettier": "^3.3.0",
    "size-limit": "^11.1.0",
    "svgo": "^3.3.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.0",
    "workbox-window": "^7.1.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
